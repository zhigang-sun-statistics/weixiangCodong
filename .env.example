# Environment Variables (copy to .env and fill in your values)

# Database
DATABASE_URL=sqlite:///./data/tasks.db

# AI Provider: openai or anthropic
AI_PROVIDER=openai

# API Keys (optional, can be configured via UI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
